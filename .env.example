# Neon PostgreSQL — same AI Video Publisher DB used by the n8n workflows
DATABASE_URL=postgres://your_neon_user:your_neon_password@ep-your-database-id.us-east-2.aws.neon.tech/neondb?sslmode=require

# Google Gemini API key (set this in n8n environment variables as GEMINI_API_KEY)
GEMINI_API_KEY=AIza...

# GetLate — personal LinkedIn account
# Set these in n8n environment variables
GETLATE_API_KEY=sk_...
GETLATE_PERSONAL_PROFILE_ID=your-getlate-profile-id
GETLATE_PERSONAL_LINKEDIN_ACCOUNT_ID=your-linkedin-account-id
