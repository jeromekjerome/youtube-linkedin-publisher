# Neon PostgreSQL — same AI Video Publisher DB used by the n8n workflows
DATABASE_URL=postgres://your_neon_user:your_neon_password@ep-your-database-id.us-east-2.aws.neon.tech/neondb?sslmode=require

# Google Gemini API key (set this in n8n environment variables as GEMINI_API_KEY)
GEMINI_API_KEY=AIza...

# LinkedIn — Person URN from your LinkedIn profile URL
# e.g. if your profile is linkedin.com/in/yourname, find your URN via the LinkedIn API
# or use https://www.linkedin.com/developers/tools/oauth to get it
# Format: urn:li:person:XXXXXXXXXX
LINKEDIN_PERSON_URN=urn:li:person:XXXXXXXXXX

# Facebook — Page ID for your Facebook page (not personal profile)
# Find it at facebook.com/your-page/about or via Graph API Explorer
FACEBOOK_PAGE_ID=your-facebook-page-id

# Instagram — Business/Creator account user ID
# Must be connected to your Facebook page
# Find it via Graph API: GET /me?fields=instagram_business_account
INSTAGRAM_USER_ID=your-instagram-user-id

# jwd.nyc WordPress — add a "WordPress" credential in n8n named "JWD Wordpress"
# pointing to https://jwd.nyc with your WP username and application password
